{
  "manifest_version": 3,
  "name": "CareerBoost Job Capture",
  "description": "Save jobs from LinkedIn, Indeed, Greenhouse and Lever, and auto-fill Greenhouse application forms (Apply Assist). Works in Chrome and Microsoft Edge.",
  "version": "0.3.0",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage", "activeTab", "identity"],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://*.linkedin.com/jobs/*",
    "https://*.indeed.com/*",
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.supabase.co/*",
    "https://*.functions.supabase.co/*",
    "https://www.careerboost.app/*",
    "https://careerboost.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*", "https://*.linkedin.com/jobs/*"],
      "js": ["shared/json-ld-job.js", "shared/capture-base.js", "linkedin.content.js"],
      "css": ["capture.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.indeed.com/*"],
      "js": ["shared/json-ld-job.js", "shared/capture-base.js", "indeed.content.js"],
      "css": ["capture.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://*.greenhouse.io/*"
      ],
      "js": ["shared/json-ld-job.js", "shared/capture-base.js", "greenhouse.content.js"],
      "css": ["capture.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://jobs.lever.co/*"],
      "js": ["shared/json-ld-job.js", "shared/capture-base.js", "lever.content.js"],
      "css": ["capture.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.careerboost.app/*",
        "https://careerboost.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["apply-assist/cb-app.bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://*.greenhouse.io/*"
      ],
      "js": ["apply-assist/greenhouse.apply.js"],
      "css": ["apply-assist/panel.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "CareerBoost",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
