{
  "manifest_version": 3,
  "name": "CareerBoost Job Capture",
  "description": "Save LinkedIn jobs directly into your CareerBoost pipeline.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://*.linkedin.com/jobs/*",
    "https://*.supabase.co/*",
    "https://*.functions.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*", "https://*.linkedin.com/jobs/*"],
      "js": ["linkedin.content.js"],
      "css": ["linkedin.content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "CareerBoost",
    "default_popup": "popup.html"
  }
}
