{
  "name": "careerboost-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Supabase backend (Postgres + RLS + Edge Functions) for the CareerBoost Job Seeker dashboard.",
  "scripts": {
    "start": "supabase start",
    "stop": "supabase stop",
    "status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff -f manual_changes",
    "fn:serve": "supabase functions serve --env-file ./.env --no-verify-jwt",
    "fn:serve:ai": "supabase functions serve ai-run --env-file ./.env --no-verify-jwt",
    "fn:deploy:ai": "supabase functions deploy ai-run --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:jobs": "supabase functions deploy jobs-search --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:import": "supabase functions deploy job-import --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:external": "supabase functions deploy external-search --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:company-intel": "supabase functions deploy company-intel-search --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:companies": "supabase functions deploy companies-search --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-tracked-companies": "supabase functions deploy admin-tracked-companies --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin": "supabase functions deploy admin-overview --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-users": "supabase functions deploy admin-users --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-list-operators": "supabase functions deploy admin-list-operators --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-promote-user": "supabase functions deploy admin-promote-user --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-incident-update": "supabase functions deploy admin-incident-update --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-list-audit": "supabase functions deploy admin-list-audit --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-credentials": "supabase functions deploy admin-credentials --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:embeddings": "supabase functions deploy embeddings --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:rerank": "supabase functions deploy jobs-rerank --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:signup-attribution": "supabase functions deploy signup-attribution --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-user-timeline": "supabase functions deploy admin-user-timeline --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:client-telemetry": "supabase functions deploy client-telemetry --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:stripe-checkout": "supabase functions deploy stripe-checkout --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:stripe-webhook": "supabase functions deploy stripe-webhook --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:stripe-portal": "supabase functions deploy stripe-portal --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:paystack-checkout": "supabase functions deploy paystack-checkout --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:paystack-webhook": "supabase functions deploy paystack-webhook --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:paystack-portal": "supabase functions deploy paystack-portal --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-promo": "supabase functions deploy admin-promo --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:my-discount": "supabase functions deploy my-discount --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:downgrade-to-free": "supabase functions deploy downgrade-to-free --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:password-recovery-update": "supabase functions deploy password-recovery-update --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-send-email": "supabase functions deploy admin-send-email --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-resend-webhook": "supabase functions deploy admin-resend-webhook --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:csp-report": "supabase functions deploy csp-report --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:health": "supabase functions deploy health --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:paystack": "npm run fn:deploy:paystack-checkout && npm run fn:deploy:paystack-webhook && npm run fn:deploy:paystack-portal && npm run fn:deploy:downgrade-to-free",
    "fn:deploy:get-entitlements": "supabase functions deploy get-entitlements --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:delete-account": "supabase functions deploy delete-account --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:restore-account": "supabase functions deploy restore-account --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:admin-user-adjust": "supabase functions deploy admin-user-adjust --project-ref kddffkhwpbngiupfmcse --no-verify-jwt",
    "fn:deploy:billing": "npm run fn:deploy:stripe-checkout && npm run fn:deploy:stripe-webhook && npm run fn:deploy:stripe-portal && npm run fn:deploy:get-entitlements",
    "test:quota-race": "deno run --allow-net --allow-env --allow-read scripts/load-test-quota-race.ts run",
    "test:quota-race:setup": "deno run --allow-net --allow-env --allow-read scripts/load-test-quota-race.ts setup",
    "test:quota-race:teardown": "deno run --allow-net --allow-env --allow-read scripts/load-test-quota-race.ts teardown",
    "fn:deploy": "npm run fn:deploy:ai && npm run fn:deploy:jobs && npm run fn:deploy:import && npm run fn:deploy:external && npm run fn:deploy:company-intel && npm run fn:deploy:admin && npm run fn:deploy:admin-users && npm run fn:deploy:admin-list-operators && npm run fn:deploy:admin-promote-user && npm run fn:deploy:admin-incident-update && npm run fn:deploy:admin-list-audit && npm run fn:deploy:admin-credentials && npm run fn:deploy:embeddings && npm run fn:deploy:rerank && npm run fn:deploy:signup-attribution && npm run fn:deploy:admin-user-timeline && npm run fn:deploy:client-telemetry && npm run fn:deploy:delete-account && npm run fn:deploy:billing",
    "secrets:push": "supabase secrets set --env-file ./.env",
    "link": "echo \"Run: supabase link --project-ref <YOUR_PROJECT_REF>\""
  },
  "devDependencies": {
    "supabase": "^2.98.2"
  },
  "engines": {
    "node": ">=18"
  }
}
