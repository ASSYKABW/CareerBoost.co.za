# =============================================================================
# CareerBoost backend — Supabase Edge Function secrets
# =============================================================================
# Copy this file to `.env` and fill in the keys you want to enable.
# Push to Supabase with:
#   npx supabase secrets set --env-file ./.env
# =============================================================================

# ---- Deployment environment & CORS -----------------------------------------
# When ENVIRONMENT=production, Edge Functions REFUSE TO START unless SITE_URL
# is set — this prevents accidentally shipping a wildcard "*" CORS policy.
# In development, leave both blank to allow any origin.
ENVIRONMENT=
# Your site origin without trailing slash (e.g. https://app.example.com).
# REQUIRED in production.
SITE_URL=

# ---- LLM providers (set at least one) --------------------------------------
# Default try order when multiple keys exist: Gemini → OpenAI → Groq → Anthropic.
# Each request uses the first provider that succeeds; later keys are fallbacks.
#
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional; default is gemini-2.0-flash (must be a Gemini model id if set).
GEMINI_MODEL=

OPENAI_API_KEY=
GROQ_API_KEY=

# Anthropic is also supported. Leave blank unless you have a paid key.
ANTHROPIC_API_KEY=

# Override the entire map (force ONE provider only — no fallback chain):
#   LLM_PROVIDER=openai
#
# Move one provider to the front for a single skill (then chain continues):
#   AI_ROUTING_RESUME_CRITIQUE=openai
LLM_PROVIDER=

# Optional default model names (OpenAI / Groq / Anthropic only). Sensible
# defaults are used if blank.
#   OpenAI default:     gpt-4.1
#   Groq default:       llama-3.3-70b-versatile
#   Anthropic default:  claude-3-5-haiku-latest
LLM_MODEL=

# Hard timeout applied to the upstream LLM call (milliseconds)
LLM_TIMEOUT_MS=25000

# ---- Optional job-board partner keys (server-side fan-out) ------------------
# If set, the jobs-search function uses these for EVERY signed-in user
# instead of requiring each user to enter their own keys in Settings.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb
MUSE_API_KEY=

# ---- Google Custom Search (external-search: LinkedIn via Google) ------------
# Create a Programmable Search Engine (search the entire web), enable the
# Custom Search API in Google Cloud, then set both values as Supabase secrets.
# https://developers.google.com/custom-search/v1/overview
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ---- RapidAPI LinkedIn (external-search primary lane) ------------------------
# LinkedIn search now uses RapidAPI first and falls back to Google CSE x-ray
# when RapidAPI fails or returns zero jobs.
# Required:
#   RAPIDAPI_KEY, RAPIDAPI_HOST, RAPIDAPI_LINKEDIN_URL
# Optional:
#   RAPIDAPI_LINKEDIN_METHOD=GET|POST (default GET)
#   RAPIDAPI_LINKEDIN_JOB_PATH=data (dot path to array in JSON response)
RAPIDAPI_KEY=
RAPIDAPI_HOST=
RAPIDAPI_LINKEDIN_URL=
RAPIDAPI_LINKEDIN_METHOD=GET
RAPIDAPI_LINKEDIN_JOB_PATH=data
